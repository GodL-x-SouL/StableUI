{
  "name": "stable-ui",
  "version": "0.4.0",
  "description": "StableUI - AI Image Generation Studio using stable-diffusion.cpp (Vue + Express)",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:server": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck": "npm run typecheck:web && npm run typecheck:server",
    "dev:server": "node build-server.cjs && node out/server/index.cjs",
    "dev:client": "vite --config vite.config.ts",
    "dev": "node build-server.cjs && concurrently \"node out/server/index.cjs\" \"vite --config vite.config.ts\"",
    "build:client": "vite build --config vite.config.ts",
    "build:server": "node build-server.cjs",
    "build": "npm run build:server && npm run build:client",
    "start": "node out/server/index.cjs",
    "preview": "npm run build && node out/server/index.cjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vueuse/core": "^14.1.0",
    "@vueuse/motion": "^3.0.3",
    "adm-zip": "^0.5.16",
    "class-variance-authority": "^0.7.1",
    "cloudflared": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.562.0",
    "multer": "^2.0.2",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tar": "^7.5.2",
    "uuid": "^11.1.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.2.6"
  }
}
